{
  "name": "mythic-market",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mythic Market — asynchronous roguelike auto-battler. Day 1 prototype.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "sim": "tsx scripts/simCombat.ts",
    "catalog": "tsx scripts/export-catalog.ts",
    "art": "tsx --env-file=.env scripts/generate-art.ts",
    "art:items": "tsx --env-file=.env scripts/generate-art.ts items",
    "art:heroes": "tsx --env-file=.env scripts/generate-art.ts heroes"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "openai": "^4.104.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
